#|
Configuration - https://github.com/jtroo/kanata/blob/main/docs/config.adoc
Examples      - https://github.com/jtroo/kanata/tree/main/cfg_samples
|#

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold yes
  linux-dev /dev/input/by-path/platform-i8042-serio-0-event-kbd
)

(defsrc caps lmet lalt)

(deflayer capslock lctl lalt lmet)

;; converting the copilot key into a ctrl key
(defchordsv2
(lsft lmet f23) lctl 200 all-released ()
)
