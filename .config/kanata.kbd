(deflayer cluster
  bks q    w    e    r    t    6    7    y    u    i    o    p     bks
  lctl a    s    d    f    g    y    u    h    j    k    l    @nu  rctl
  lalt  z    x    c    v    b    h    b    n    m    @sy  @en  ralt
  lsft z    lmet lmet lmet b    n    m    ralt ralt /    rsft
  lctl lmet lalt           spc            rsft @vi
)
