window:
  padding:
    x: 6
    y: 6

shell:
  program: /usr/bin/fish

font:
  normal:
    family: FiraCode Nerd Font
    style: Medium
  bold:
    family: FiraCode Nerd Font
    style: Bold
  italic:
    family: FiraCode Nerd Font
    style: Italic
  bold_italic:
    family: FiraCode Nerd Font
    style: Bold Italic
  size: 12.5

key_bindings:
  - { key: V, mods: Control|Shift, action: Paste }
  - { key: P, mods: Alt, action: Paste }
  - { key: C, mods: Control|Shift, action: Copy }
  - { key: Y, mods: Alt, action: Copy }
  - { key: Insert, mods: Shift, action: PasteSelection }
  - { key: Paste, mods: None, action: Paste }
  - { key: Copy, mods: None, action: Copy }
  - { key: L, mods: Control, action: ClearLogNotice }
  - { key: V, mods: Alt, action: ToggleViMode }
  # - { key: C, mods: Alt, command: {program: "gela", args: ["t"]}} moved to config.fish
  - {
      key: U,
      mods: Alt,
      action: ScrollHalfPageUp,
      mode: ~Alt
    }
  - {
      key: D,
      mods: Alt,
      action: ScrollHalfPageDown,
      mode: ~Alt
    }
  - {
      key: PageUp,
      mods: Alt,
      action: ScrollToTop,
      mode: ~Alt
    }
  - {
      key: PageDown,
      mods: Alt,
      action: ScrollToBottom,
      mode: ~Alt
    }
  - { key: L, mods: Control, chars: "\f" }
colors:
  # Default colors
  primary:
    background: '0x0d1117'
    foreground: '0xb3b1ad'

  # Normal colors
  normal:
    black: '0x484f58'
    red: '0xff7b72'
    green: '0x3fb950'
    yellow: '0xd29922'
    blue: '0x58a6ff'
    magenta: '0xbc8cff'
    cyan: '0x39c5cf'
    white: '0xb3b1ad'

  # Bright colors
  bright:
    black: '0x6e7681'
    red: '0xffa198'
    green: '0x56d364'
    yellow: '0xe3b341'
    blue: '0x79c0ff'
    magenta: '0xd2a8ff'
    cyan: '0x39c5cf'
    white: '0xb3b1ad'

  indexed_colors:
    - { index: 16, color: '0xd18616' }
    - { index: 17, color: '0xffa198' }
theme: github_dark_default
