window:
  padding:
    x: 6
    y: 6

shell:
  program: /usr/bin/fish

font:
  normal:
    family: FiraCode Nerd Font
    style: Medium
  bold:
    family: FiraCode Nerd Font
    style: Bold
  italic:
    family: FiraCode Nerd Font
    style: Italic
  bold_italic:
    family: FiraCode Nerd Font
    style: Bold Italic
  size: 12.5

key_bindings:
  - { key: V, mods: Control|Shift, action: Paste }
  - { key: P, mods: Alt, action: Paste }
  - { key: C, mods: Control|Shift, action: Copy }
  - { key: Y, mods: Alt, action: Copy }
  - { key: Insert, mods: Shift, action: PasteSelection }
  - { key: Paste, mods: None, action: Paste }
  - { key: Copy, mods: None, action: Copy }
  - { key: L, mods: Control, action: ClearLogNotice }
  - { key: V, mods: Alt, action: ToggleViMode }
  # - { key: C, mods: Alt, command: {program: "gela", args: ["t"]}} moved to config.fish
  - {
      key: U,
      mods: Alt,
      action: ScrollHalfPageUp,
      mode: ~Alt
    }
  - {
      key: D,
      mods: Alt,
      action: ScrollHalfPageDown,
      mode: ~Alt
    }
  - {
      key: PageUp,
      mods: Alt,
      action: ScrollToTop,
      mode: ~Alt
    }
  - {
      key: PageDown,
      mods: Alt,
      action: ScrollToBottom,
      mode: ~Alt
    }
  - { key: L, mods: Control, chars: "\f" }
colors:
  name: Google (light)
  author: Chris Kempson
  primary:
    background: "#ffffff"
    foreground: "#373b41"
  cursor:
    text: "#ffffff"
    cursor: "#373b41"
  normal:
    black: "#1d1f21"
    red: "#cc342b"
    green: "#198844"
    yellow: "#fba922"
    blue: "#3971ed"
    magenta: "#a36ac7"
    cyan: "#3971ed"
    white: "#c5c8c6"
  bright:
    black: "#969896"
    red: "#cc342b"
    green: "#198844"
    yellow: "#fba922"
    blue: "#3971ed"
    magenta: "#a36ac7"
    cyan: "#3971ed"
    white: "#ffffff"
theme: Google.light
