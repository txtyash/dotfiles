window:
  padding:
    x: 6
    y: 6

shell:
  program: /usr/bin/fish

font:
  normal:
    family: FiraCode Nerd Font
    style: Medium
  bold:
    family: FiraCode Nerd Font
    style: Bold
  italic:
    family: FiraCode Nerd Font
    style: Italic
  bold_italic:
    family: FiraCode Nerd Font
    style: Bold Italic
  size: 12.5

key_bindings:
  - { key: V, mods: Control|Shift, action: Paste }
  - { key: P, mods: Alt, action: Paste }
  - { key: C, mods: Control|Shift, action: Copy }
  - { key: Y, mods: Alt, action: Copy }
  - { key: Insert, mods: Shift, action: PasteSelection }
  - { key: Paste, mods: None, action: Paste }
  - { key: Copy, mods: None, action: Copy }
  - { key: L, mods: Control, action: ClearLogNotice }
  - { key: V, mods: Alt, action: ToggleViMode }
  # - { key: C, mods: Alt, command: {program: "gela", args: ["t"]}} moved to config.fish
  - { key: U, mods: Alt, action: ScrollHalfPageUp, mode: ~Alt }
  - { key: D, mods: Alt, action: ScrollHalfPageDown, mode: ~Alt }
  - { key: PageUp, mods: Alt, action: ScrollToTop, mode: ~Alt }
  - { key: PageDown, mods: Alt, action: ScrollToBottom, mode: ~Alt }
  - { key: L, mods: Control, chars: "\f" }
colors:
  # Default colors
  primary:
    # hard contrast: background = '#f9f5d7'
    background: "#fbf1c7"
    # soft contrast: background = '#f2e5bc'
    foreground: "#3c3836"

  # Normal colors
  normal:
    black: "#fbf1c7"
    red: "#cc241d"
    green: "#98971a"
    yellow: "#d79921"
    blue: "#458588"
    magenta: "#b16286"
    cyan: "#689d6a"
    white: "#7c6f64"

  # Bright colors
  bright:
    black: "#928374"
    red: "#9d0006"
    green: "#79740e"
    yellow: "#b57614"
    blue: "#076678"
    magenta: "#8f3f71"
    cyan: "#427b58"
    white: "#3c3836"
theme: Gruvbox-Light
