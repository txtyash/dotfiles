window:
  padding:
    x: 6
    y: 6

shell:
  program: /usr/bin/fish

font:
  normal:
    family: FiraCode Nerd Font
    style: Medium
  bold:
    family: FiraCode Nerd Font
    style: Bold
  italic:
    family: FiraCode Nerd Font
    style: Italic
  bold_italic:
    family: FiraCode Nerd Font
    style: Bold Italic
  size: 12.5

key_bindings:
  - { key: V, mods: Control|Shift, action: Paste }
  - { key: P, mods: Alt, action: Paste }
  - { key: C, mods: Control|Shift, action: Copy }
  - { key: Y, mods: Alt, action: Copy }
  - { key: Insert, mods: Shift, action: PasteSelection }
  - { key: Paste, mods: None, action: Paste }
  - { key: Copy, mods: None, action: Copy }
  - { key: L, mods: Control, action: ClearLogNotice }
  - { key: V, mods: Alt, action: ToggleViMode }
  # - { key: C, mods: Alt, command: {program: "gela", args: ["t"]}} moved to config.fish
  - {
      key: U,
      mods: Alt,
      action: ScrollHalfPageUp,
      mode: ~Alt
    }
  - {
      key: D,
      mods: Alt,
      action: ScrollHalfPageDown,
      mode: ~Alt
    }
  - {
      key: PageUp,
      mods: Alt,
      action: ScrollToTop,
      mode: ~Alt
    }
  - {
      key: PageDown,
      mods: Alt,
      action: ScrollToBottom,
      mode: ~Alt
    }
  - { key: L, mods: Control, chars: "\f" }
colors:
  # Default colors
  primary:
    background: '0x1E1D2F'
    foreground: '0xD9E0EE'

  cursor:
    text: '0x1E1D2F'
    cursor: '0xF5E0DC'

  # Normal colors
  normal:
    black: '0x6E6C7E'
    red: '0xF28FAD'
    green: '0xABE9B3'
    yellow: '0xFAE3B0'
    blue: '0x96CDFB'
    magenta: '0xF5C2E7'
    cyan: '0x89DCEB'
    white: '0xD9E0EE'

  # Bright colors
  bright:
    black: '0x988BA2'
    red: '0xF28FAD'
    green: '0xABE9B3'
    yellow: '0xFAE3B0'
    blue: '0x96CDFB'
    magenta: '0xF5C2E7'
    cyan: '0x89DCEB'
    white: '0xD9E0EE'

  indexed_colors:
    - { index: 16, color: '0xF8BD96' }
    - { index: 17, color: '0xF5E0DC' }
theme: Catppuccin
