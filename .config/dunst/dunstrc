// TODO: Configure further
[global]
    frame_color = "#504945"
    separator_color = "#504945"
    font = JetBrainsMono Nerd Font Regular 9
    markup = full
    format = "<b>%a</b>\n\n<b>%s</b>\n%b"
    alignment = center
    follow = keyboard
    geometry = "300x10-30+20"
    ignore_newline = no
    padding = 12

    separator_color = frame
    separator_height = 2

    icon_corner_radius = 0
    icon_corners = all
    icon_theme = Adwaita
    icon_position = left
    min_icon_size = 32
    max_icon_size = 128
    # TODO: add icon path
    startup_notification = false

    # TODO: add browser path
    browser = /usr/bin/firefox -new-tab

[base16_low]
    msg_urgency = low
    background = "#ebdbb2"
    foreground = "#bdae93"

[base16_normal]
    msg_urgency = normal
    background = "#d5c4a1"
    foreground = "#504945"

[base16_critical]
    msg_urgency = critical
    background = "#9d0006"
    foreground = "#3c3836"

[shortcuts]
    close_all = mod4+shift+m
    history = mod4+n

# vim: ft=cfg
